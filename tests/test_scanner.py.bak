import pytest
from unittest.mock import patch, AsyncMock
from fastapi.testclient import TestClient
from main import app
from app.models import ScanSubmitRequest, ScanOptions
from app.services.scanner import ScannerService


client = TestClient(app)


def test_build_nmap_command_single_ip():
    """测试构建针对单个IP的nmap命令"""
    scanner = ScannerService()
    cmd = scanner.build_nmap_command("192.168.1.1")
    # 基础命令应该包含 nmap -sS -A -T4 -oX - <target>
    assert cmd[0] == "nmap"
    assert "-sS" in cmd
    assert "-A" in cmd  # -A包含了-O和-sV
    assert "-T4" in cmd
    assert "192.168.1.1" in cmd


def test_build_nmap_command_cidr():
    """测试构建针对CIDR的nmap命令"""
    scanner = ScannerService()
    cmd = scanner.build_nmap_command("192.168.1.0/24")
    assert "192.168.1.0/24" in cmd
    assert "-sS" in cmd
    assert "-A" in cmd


def test_build_nmap_command_with_options():
    """测试带不同选项的nmap命令构建"""
    scanner = ScannerService()
    scan_options = ScanOptions(
        port_scan=True,
        os_detection=True,
        vendor_detection=True
    )
    cmd = scanner.build_nmap_command("192.168.1.1", scan_options)
    assert "192.168.1.1" in cmd
    assert "-sS" in cmd
    # 当所有选项都启用时，-A会取代-O和-sV
    assert "-A" in cmd
    assert "-T4" in cmd


def test_build_nmap_command_disabled_options():
    """测试禁用选项的nmap命令构建"""
    scanner = ScannerService()
    scan_options = ScanOptions(
        port_scan=False,
        os_detection=False,
        vendor_detection=False
    )
    cmd = scanner.build_nmap_command("192.168.1.1", scan_options)
    assert "192.168.1.1" in cmd
    assert "-sS" in cmd
    # 即使所有选项都禁用，也会包含基本参数
    assert "-T4" in cmd


@pytest.mark.asyncio
@patch('app.services.scanner.asyncio.create_subprocess_exec')
async def test_scan_success_mock(mock_proc):
    """测试模拟扫描成功的情况"""
    # 设置mock过程
    mock_process = AsyncMock()
    mock_process.communicate.return_value = (b'<nmaprun><host><address addr="127.0.0.1" addrtype="ipv4"/><status state="up"/></host></nmaprun>', b'')
    mock_process.returncode = 0
    mock_proc.return_value = mock_process

    scanner = ScannerService()
    request = ScanSubmitRequest(target="127.0.0.1")
    task_id = "test_task_123"

    # 模拟任务存储
    from app.services.task_manager import task_manager
